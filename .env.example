# Cloudflare configuration
# Find these at: https://dash.cloudflare.com → your domain → Overview (right sidebar)
CLOUDFLARE_API_TOKEN=        # API token with: Workers, D1, DNS, Email Routing, Access permissions
CLOUDFLARE_ACCOUNT_ID=       # Account ID
CLOUDFLARE_ZONE_ID=          # Zone ID for your domain

# DMARC configuration
DMARC_EMAIL=dmarc            # Local part of the receiving address (domain auto-detected from zone)

# External report authorization (optional, comma-separated)
# Domains that will send DMARC reports to this address.
# Creates <domain>._report._dmarc TXT records.
# Leave empty to create a wildcard (*._report._dmarc) accepting reports from any domain.
REPORT_AUTHORIZED_DOMAINS=   # e.g. "otherdomain.com,another.org" — or leave empty for wildcard

# Cloudflare Access — who can view the dashboard (comma-separated)
ACCESS_ALLOWED_EMAILS=       # e.g. "you@gmail.com,coworker@outlook.com"
