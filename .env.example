# Cloudflare configuration
# Find these at: https://dash.cloudflare.com → your domain → Overview (right sidebar)
# API token with: Workers, D1, DNS, Email Routing, Access permissions
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# DMARC configuration
# Local part of the receiving address (domain auto-detected from zone)
DMARC_EMAIL=dmarc

# External report authorization (optional, comma-separated)
# Domains that will send DMARC reports to this address.
# Creates <domain>._report._dmarc TXT records.
# Leave empty to create a wildcard (*._report._dmarc) accepting reports from any domain.
# e.g. "otherdomain.com,another.org" — or leave empty for wildcard
REPORT_AUTHORIZED_DOMAINS=

# Cloudflare Access — who can view the dashboard (at least one must be set)
# Identity rules (comma-separated; both can be set and are combined with OR):
# e.g. "you@gmail.com,coworker@outlook.com"
ACCESS_ALLOWED_EMAILS=
# e.g. "company.com,partner.org"
ACCESS_ALLOWED_EMAIL_DOMAINS=
# IP restriction (comma-separated CIDRs; AND'd with identity rules when both are set):
# e.g. "10.0.0.0/8,203.0.113.0/24"
ACCESS_ALLOWED_IPS=
